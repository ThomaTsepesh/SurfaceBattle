.main-menu {
    position: absolute;
    left: 50%;
    top: 50%;
}

.start-btn {
    background-color: rgba(40, 40, 40, 0.9);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 4px;
    padding: 12px 48px;
    font-size: 16px;
    min-width: 180px;
}

.start-btn:hover {
    background-color: rgba(60, 60, 60, 0.9);
}